                        <% }); %>
                    </div>
                    <div class="tab-panel vact-sample">
                        <% vactSampleDocuments.forEach(function(doc) { %>
                        <div class="card">
                            <img src="<%= doc.image %>" alt="<%= doc.title %>">
                            <p><%= doc.title %></p>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        </div>
